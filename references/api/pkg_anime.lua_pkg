	LM_Vector2	drawingVec;
	LM_Vector2	startVec;
	LM_Vector2	drawingStartVec;
	uint32		mouseBut;
	bool		shiftKey;
	bool		ctrlKey;
	bool		altKey;
	real		penPressure;
	bool		doubleClick;
	bool		isPenEvent;
	bool		eraser;
};

class KeyEvent {
	MohoView	*view;

	char		*key;
	int32		keyCode;
	bool		shiftKey;
	bool		ctrlKey;
	bool		altKey;
};

