class ScriptInterface {
	int32		fFrame @ frame;
	int32		fDrawingFrame @ drawingFrame;
	int32		fLayerFrame @ layerFrame;
	int32		fDrawingLayerFrame @ drawingLayerFrame;
	MohoDoc		*fDoc @ document;
	MohoLayer	*fLayer @ layer;
	MohoLayer	*fDrawingLayer @ drawingLayer;
	MohoView	*fView @ view;
	bool		fGridOn @ gridOn;
	real		fGridSize @ gridSize;

	const char *AppVersion();
	bool IsPro();

	void Quit();
	void Click();

	void SetCurFrame(int32 frame, bool updateUI = true, bool enableBoneDynamics = false);
	void UpdateUI();
	bool IsPlaying();

	bool IsCopyable();
	void Copy(M_Mesh *mesh = NULL);
	void CopyAlternate(M_Mesh *mesh = NULL);
	bool IsPasteable();
	void Paste();
	void PasteAlternate();
	void CopyText(const char *text);
	void CopyColor(rgb_color color);
	const char *ClipboardText();

	bool CheckIfLocked(MohoLayer *layer, bool showAlert);
	
	void NewKeyframe(int32 channel);
	void UpdateSelectedChannels();

	bool DisableDrawingTools();
	const char *CurrentTool();

	void SetSelLayer(MohoLayer *layer, bool multiSelect = false, bool allowDeselect = true);
	void AlignLayers(AlignmentMessage alignMessage);
	void ShowLayerInLayersPalette(MohoLayer *layer);
	MohoLayer *CreateNewLayer(int32 layerType, bool undoable = true);
	MohoLayer *DuplicateLayer(MohoLayer *layer, bool byReference = false);
	void DeleteLayer(MohoLayer *layer);
	void DeleteMultipleLayers();
	void PlaceLayerInGroup(MohoLayer *child, MohoLayer *group, bool top = true, bool isUndoable = true);
	void PlaceLayerBehindAnother(MohoLayer *moveLayer, MohoLayer *behindThis);
	MeshLayer *LayerAsVector(MohoLayer *layer);
	ImageLayer *LayerAsImage(MohoLayer *layer);
	GroupLayer *LayerAsGroup(MohoLayer *layer);
	BoneLayer *LayerAsBone(MohoLayer *layer);
	SwitchLayer *LayerAsSwitch(MohoLayer *layer);
	ParticleLayer *LayerAsParticle(MohoLayer *layer);
	Mesh3DLayer *LayerAs3D(MohoLayer *layer);
	AudioLayer *LayerAsAudio(MohoLayer *layer);
	NoteLayer *LayerAsNote(MohoLayer *layer);

	AnimBool *ChannelAsAnimBool(AnimChannel *ch);
	AnimColor *ChannelAsAnimColor(AnimChannel *ch);
	AnimString *ChannelAsAnimString(AnimChannel *ch);
	AnimVal *ChannelAsAnimVal(AnimChannel *ch);
	AnimVec2 *ChannelAsAnimVec2(AnimChannel *ch);
	AnimVec3 *ChannelAsAnimVec3(AnimChannel *ch);

	void EditLayerSettings();
	
	M_Mesh *Mesh();
	M_Mesh *DrawingMesh();
	M_Shape *SelectedShape(); // returns the first selected shape, but starting in version 10 there may be multiple selected shapes
	void DeselectShapes();
	M_Shape *NewShapeProperties();
	M_Style *CurrentEditStyle();
	void SnapToGrid(LM_Vector2 &v);
	void AddPointKeyframe(int32 frame, MohoLayer *layer = NULL, bool allSelectedKeys = false);
	int32 CreateShape(bool filled, bool behindNeighborStrokes = false, int32 frame = -1000000, bool checkForBadShapes = true, bool skipDuplicateStrokes = false, bool skipFill = false, bool skipLine = false);
	int32 TraceWhitePixels(int32 frame, int32 gapFilling = 0);
	bool RestoreTracingImage();
	void SaveTracingImage();
	void PurgeTracingImage();
	void DrawShape(LM_Graphics *g, M_Mesh *mesh, int32 shapeID);
	rgb_color NewShapeFillColor();
	rgb_color NewShapeLineColor();
	real NewShapeLineWidth();
	void SetNewShapeLineWidth(real width);
		// The following method is deprecated, but remains for older scripts.
		// Use the new void InsertText(int32 lineOffset, InsertTextParams *textParams) method instead
	void InsertText(const char *text, const char *font, bool fill, bool stroke, bool groupTogether, bool centerH, int32 lineOffset);
	void InsertText(InsertTextParams *textParams, int32 lineOffset);
	void PickStyleProperties(M_Shape *fromShape, bool skipFill = false, bool skipLine = false);
	void PushStyleProperties(M_Shape *toShape, bool skipFill = false, bool skipLine = false);

	M_Skeleton *Skeleton();
	M_Skeleton *ParentSkeleton();
	void UpdateBonePointSelection();

	M_Mesh3D *Mesh3D();

	bool HasMaximumWarpLayers();
	bool HasMaximumSmartBones();

	int32 CountAudioLayers();
	AudioLayer *GetAudioLayer(int32 id);

	// coordinate conversions
	real PixelToDoc(real pixel);
	real DocToPixel(real doc);

	int32 CountPoints();
	int32 CountSelectedPoints(bool updateCount = false);
	int32 CountCurves();
	int32 CountSelectedCurves(bool updateCount = false);
	int32 CountEdges();
	int32 CountSelectedEdges(bool updateCount = false);
	int32 CountShapes();
	int32 CountSelectedShapes(bool updateCount = false);
	int32 CountFilledShapes();
	int32 CountSelectedFilledShapes();

	int32 CountBones();
	int32 CountSelectedBones(bool updateCount = false);

	void CreateTextObject();
	void FillInFontList(LM_TextList *list);

	LM_Vector3 NoiseVector(LM_Vector3 &pos, real amp, real freq);
	bool AnglesEquivalent(real a1, real a2, real threshold = 1e-6f);

	void ImportEPS(const char *path);

	const char *AppDir(bool variantDir);
	const char *UserAppDir();
	const char *ExporterPath();
	const char *UserPrefsDir();
	const char *UserPrefsFile();
	const char *UserContentDir();

	void BeginFileListing(const char *dir, bool listHiddenAndSystemFiles = true);
	const char *GetNextFile();

	MohoDoc *LoadDocument(const char *path);
	void DestroyDocument(MohoDoc *doc);
	
	void OpenPoserPalette();
	
	void FileNew();
	void FileOpen(const char *path);
	void FileClose();
	void FileSave();
	void FileSaveAs(const char *path);
	void FileImport(const char *path, int32 mode = 0); // mode (only applies to Anime files): 0=import as copy, 1=import as reference, 2=ask the user
	void FileRender(const char *path); // path should end in .bmp, .jpg, .png, or .tga

	void PresentFile(const char *path); // Open file in the default app, or display it in the Finder/Explorer, etc.

	LayersWindowSearchContext LayersWindowGetSearchContext();
	void LayersWindowSetSearchContext(LayersWindowSearchContext context);
	const char* LayersWindowGetSearchContextValue();
	void LayersWindowSetSearchContextValue(const char *val);
};

/*
	The ScriptInterfaceHelper class is a bit special.
	It allows you to access sensitive resources that must be released when you're done with them.
	Unlike most objects, it must be explicitly deleted when you're done using it, like so:

	local helper = MOHO.ScriptInterfaceHelper:new_local()
	local moho = helper:MohoObject()
	print(moho:CountPoints())
	helper:delete()
*/

class ScriptInterfaceHelper {
public:
	ScriptInterfaceHelper();
	~ScriptInterfaceHelper();
	static ScriptInterfaceHelper *new_local();

	ScriptInterface *MohoObject();
};

