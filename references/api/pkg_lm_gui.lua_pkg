$#include "lm_pkg_lm_gui.h"
/* tolua -o pkg_lm_gui.cpp -H pkg_lm_gui.h pkg_lm_gui.lua_pkg */

typedef int				int32;
typedef unsigned int	uint32;
typedef float			real;



module LM { // begin module
module GUI { // begin module

/**********************************************************************/
/*** Key Codes ***/

