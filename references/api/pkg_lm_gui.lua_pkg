extern LM_ColorSwatch *WF_ShortColorSwatch @ ShortColorSwatch(bool allowAlpha, int32 msg = 0);
extern LM_AngleWidget *WF_AngleWidget @ AngleWidget(int32 msg = 0, bool horizontal = false);
extern LM_Button *WF_ImageButton @ ImageButton(const char *path, const char *tooltip, bool checkbox, int32 msg = 0, bool recolor = false);
extern LM_Cursor *WF_Cursor @ Cursor(const char *path, int32 hotX, int32 hotY);
extern LM_Slider *WF_Slider @ Slider(int32 length, bool vertical, bool showTicks, int32 msg = 0, uint32 resizingMode = LM_FOLLOW_LEFT);
