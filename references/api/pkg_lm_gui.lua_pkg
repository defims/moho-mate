extern LM_PopupMenu *WF_PopupMenu @ PopupMenu(int32 width, bool radioMode = true);
extern LM_PopupMenu *WF_ImagePopupMenu @ ImagePopupMenu(const char *path, bool radioMode = true, bool recolor = false);
