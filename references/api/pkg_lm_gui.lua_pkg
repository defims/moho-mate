	int32 Value();
	void SetRange(int32 min, int32 max);
	void SetConstantMessages(bool b);
	void SetFatSlider(bool b);
	void SetShowTicks(bool b);
	bool GetShowTicks();
	void SetSnapToTicks(bool b); // only valid if showTicks is true
	bool GetSnapToTicks();

	void SetNumTicks(int32 numTicks);
	int32 GetNumTicks();
};

class LM_ScrollBar : public LM_BaseWidget {
	void SetValue(int32 value);
	void SetValueWithMessage(int32 value);
	int32 Value();
	void SetRange(int32 min, int32 max);
	void GetRange(int32 *min, int32 *max);
	void SetStepSize(int32 smallStep, int32 largeStep);
};

