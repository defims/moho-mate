	void SetAllowsMultipleSelection(bool allow);
	void SetDrawsPrimarySelection(bool drawPrimary);
	bool DrawsPrimarySelection();
	void ScrollItemIntoView(int32 itemIndex, bool scrollToTop = false);
	int32 NumSelectedItems();
	const char *GetSelItem(int32 selItemIndex);
	bool IsItemSelected(int32 itemIndex);
};


class LM_ColorSwatch : public LM_BaseWidget {
