/*** Widgets ***/

#define LM_FOLLOW_LEFT @ FOLLOW_LEFT
#define LM_FOLLOW_TOP @ FOLLOW_TOP
#define LM_FOLLOW_RIGHT @ FOLLOW_RIGHT
#define LM_FOLLOW_BOTTOM @ FOLLOW_BOTTOM

#define LM_DEFAULT_PADDING @ DEFAULT_PADDING
#define LM_DEFAULT_INDENT @ DEFAULT_INDENT

#define LM_ALIGN_LEFT @ ALIGN_LEFT
#define LM_ALIGN_TOP @ ALIGN_TOP
#define LM_ALIGN_CENTER @ ALIGN_CENTER
#define LM_ALIGN_RIGHT @ ALIGN_RIGHT
#define LM_ALIGN_BOTTOM @ ALIGN_BOTTOM
#define LM_ALIGN_FILL @ ALIGN_FILL

class LM_View {
	int32 Width();
	int32 Height();

	bool IsMouseDragging(uint32 button = 0);

	void Enable(bool enable);
	bool IsEnabled();
	
	void SetCursor(LM_Cursor *cursor);
	void SetToolTip(const char *tooltip);
};

class LM_BaseWidget : public LM_View {
	void Redraw();
};

class LM_StaticText : public LM_BaseWidget {
};

class LM_DynamicText : public LM_BaseWidget {
	void SetValue(const char *text);
	void SetValue(int32 i);
	void SetValue(real f);
};

class LM_Divider : public LM_BaseWidget {
};

class LM_Button : public LM_BaseWidget {
	void SetValue(bool value);
	bool Value();

	void SetLabel(const char *label, bool adjustSize = true);
	void SetImage(const LM_image *img, int32 desiredImageWidth = 0, int32 desiredImageHeight = 0, bool redraw = true);
	void ReplaceImage(const char *path, bool recolor = false);
	void SetToolTip(const char *tooltip);
	void SetContinuousMessages(real intervalSecs);
	void SetAlternateMessage(int32 altMsg); // this message will get sent if the user holds down the alt key while clicking the button
	void SetAltMessage(int32 altMsg); // (same as above, but with better naming now that we support Shift and Ctrl too)
	void SetShiftMessage(int32 alternateMsg); // this message will get sent if the user holds down the shift key while clicking the button
	void SetCtrlMessage(int32 alternateMsg); // this message will get sent if the user holds down the ctrl key while clicking the button
};

class LM_ShortButton : public LM_BaseWidget {
	void SetLabel(const char *label);
	void SetAltMessage(int32 altMsg); // this message will get sent if the user holds down the alt key while clicking the button
	void SetShiftMessage(int32 shiftMsg); // this message will get sent if the user holds down the shift key while clicking the button
	void SetCtrlMessage(int32 ctrlMsg); // this message will get sent if the user holds down the ctrl key while clicking the button
};

class LM_CheckBox : public LM_BaseWidget {
	void SetValue(bool value);
	bool Value();
};

class LM_RadioButton : public LM_BaseWidget {
	void SetValue(bool value);
	bool Value();
};

#define LM_FIELD_TEXT @ FIELD_TEXT
#define LM_FIELD_INT @ FIELD_INT
#define LM_FIELD_FLOAT @ FIELD_FLOAT
