/**********************************************************************/
/*** Anim Channels ***/

#define CHANNEL_UNKNOWN
#define CHANNEL_VAL
#define CHANNEL_VEC2
#define CHANNEL_COLOR
#define CHANNEL_BOOL
#define CHANNEL_STRING
#define CHANNEL_VEC3

#define INTERP_LINEAR
#define INTERP_SMOOTH
#define INTERP_EASE
#define INTERP_STEP
#define INTERP_NOISY
#define INTERP_CYCLE
#define INTERP_POSE
#define INTERP_EASE_IN
#define INTERP_EASE_OUT
#define INTERP_BEZIER
#define INTERP_BOUNCE
#define INTERP_ELASTIC

#define KEY_SELECTED

// val1 and val2 have specific meanings for different interpolation types
// INTERP_NOISY - val1 = noise amplitude		val2 = noise scale
//		good values: 0.1, 0.5
// INTERP_CYCLE - val1 = relative starting frame (count back this many frames and start again)
//		val2 = absolute starting frame (count back to exactly this frame, use -1 to ignore this field)
// INTERP_POSE - val1 = index to the pose
class InterpSetting {
	InterpSetting();
	~InterpSetting();
	static InterpSetting *new_local();

	void Reset();

	bool IsAdditiveCycle();
	void SetAdditiveCycle(bool b);

	real BezierOutAngle(int32 component);
	void SetBezierOutAngle(int32 component, real angle);
	real BezierInAngle(int32 component);
	void SetBezierInAngle(int32 component, real angle);
	
	real BezierOutPercentage(int32 component);
	void SetBezierOutPercentage(int32 component, real percent);
	real BezierInPercentage(int32 component);
	void SetBezierInPercentage(int32 component, real percent);

	int32	interpMode;
	real	val1;
	real	val2;
	int32	interval; // 1 to interpolate every frame, 2 to animate on 2's, 3 to animate on 3's, etc.
	int32	hold; // how many frames to hold the previous value before interpolating to the next
	bool	stagger;
	int32	tags; // used for keyframe color, and possibly other stuff in the future
	uint8	flags;
};

class AnimChannel {
	int32 ChannelType();

	int32 CountKeys();
	int32 Duration();

	void Clear(int32 zeroFrame);
	void ClearAfter(int32 frame);
	void ClearBefore(int32 frame);

	void Mute(bool b);
	bool IsMuted();

	void StoreValue();
	void AddKey(int32 when);
	void Reset(int32 when);

	bool HasKey(int32 when);
	int32 GetClosestKeyID(int32 when);
	void DeleteKey(int32 when);
	void DeleteKeyByID(int32 id);
	void SwapKeys(int32 id1, int32 id2);

	int32 GetKeyWhen(int32 id);
	void SetKeyWhen(int32 id, int32 when);
	void SetKeyWhenNoRestriction(int32 id, int32 when); // allow keyframes to be set before/after each other, or even on top of each other
	void MakeKeyframesConsistent(bool deleteDuplicates); // make sure the keyframes are all in order according to time, and remove any that overlap

	void SetKeyInterp(int32 when, int32 interpMode, real val1, real val2);
	void SetKeyInterpByID(int32 id, int32 interpMode, real val1, real val2);
	void SetKeyInterp(int32 when, InterpSetting &interp);
	void SetKeyInterpByID(int32 id, InterpSetting &interp);
	void GetKeyInterp(int32 when, InterpSetting &interp);
	void GetKeyInterpByID(int32 id, InterpSetting &interp);
	void GetKeyInterp(int32 when, int32 *interpMode, real *val1, real *val2);
	void GetKeyInterpByID(int32 id, int32 *interpMode, real *val1, real *val2);
	int32 GetKeyInterpMode(int32 when);
	int32 GetKeyInterpModeByID(int32 id);

	void SetKeySelected(int32 when, bool sel);
	bool IsKeySelected(int32 when);
	void SetKeySelectedByID(int32 id, bool sel);
	bool IsKeySelectedByID(int32 id);

	int32 PoseCount @ CountActions();
	const char *PoseName @ ActionName(int32 id);
	const char *ActivePose @ CurrentAction();
	void SetActivePose @ ActivateAction(const char *name);
	AnimChannel *Pose @ Action(int32 id);
	AnimChannel *PoseByName @ ActionByName(const char *name);
	virtual void InsertPose @ InsertAction(const char *name, int32 when);
	void InsertPoseByReference @ InsertActionByReference(const char *name, int32 when);
};

class AnimVal : public AnimChannel {
	void SetValue(int32 when, real val);
	real GetValue(int32 when);
	
	void SetValueByID(int32 id, real val);
	real GetValueByID(int32 id);

	real	value;
};

class AnimVec2 : public AnimChannel {
	void SetValue(int32 when, LM_Vector2 val);
	LM_Vector2 GetValue(int32 when);
	
	void SetValueByID(int32 id, LM_Vector2 val);
	LM_Vector2 GetValueByID(int32 id);

	void SplitDimensions(bool b);
	bool AreDimensionsSplit();
	void SyncSplitDimensionsBack();
	AnimVal *DimensionChannel(int32 dim); // 0:X 1:Y

	LM_Vector2	value;
};

class AnimColor : public AnimChannel {
	void SetValue(int32 when, LM_ColorVector val);
	void SetValue(int32 when, rgb_color val);
	LM_ColorVector GetValue(int32 when);
	
	void SetValueByID(int32 id, LM_ColorVector val);
	void SetValueByID(int32 id, rgb_color val);
	LM_ColorVector GetValueByID(int32 id);

	rgb_color	value;
};

class AnimBool : public AnimChannel {
	void SetValue(int32 when, bool val);
	bool GetValue(int32 when);
	
	void SetValueByID(int32 id, bool val);
	bool GetValueByID(int32 id);

	bool	value;
};

class AnimString : public AnimChannel {
	void SetValue(int32 when, const char *);
	const char *GetValue(int32 when);
	
	void SetValueByID(int32 id, const char *);
	const char *GetValueByID(int32 id);

	LM_String	value;
};

class AnimVec3 : public AnimChannel {
	void SetValue(int32 when, LM_Vector3 val);
	LM_Vector3 GetValue(int32 when);
	
	void SetValueByID(int32 id, LM_Vector3 val);
	LM_Vector3 GetValueByID(int32 id);

	void SplitDimensions(bool b);
	bool AreDimensionsSplit();
	void SyncSplitDimensionsBack();
	AnimVal *DimensionChannel(int32 dim); // 0:X 1:Y 2:Z

	LM_Vector3	value;
};

