	void SetSkiaScaleFactor(real scaleFactor); // Set to 0 or less to revert to built-in default
	real InverseSkiaScaleFactor();

	int32 GetNumPoints @ CountPoints();
	int32 GetNumVisiblePoints @ CountVisiblePoints();
	int32 GetNumCurves @ CountCurves();
	int32 GetNumShapes @ CountShapes();
	int32 GetNumGroups @ CountGroups();
	M_Point *GetPoint @ Point(int32 id);
	M_Point	*GetVisiblePoint @ VisiblePoint(int32 id);
	M_Curve *GetCurve @ Curve(int32 id);
	M_Shape *GetShape @ Shape(int32 id);
	M_Shape *GetShape @ ShapeByName(const char *name);
	M_Shape *GetShapeByID @ ShapeByID(int32 id);
	M_PointGroup *GetGroup @ Group(int32 id);

	M_Shape *GetUserEdgeShape @ UserEdgeShape();

	void AddPoint(LM_Vector2 &pos, int32 attachID, int32 frame);
	void AddPoint(LM_Vector2 &pos, int32 attachCurve, int32 attachSeg, int32 frame, bool correctBezierHandles = true, bool preserveCorners = false);
	void AddLonePoint(LM_Vector2 pos, int32 frame);
	void AppendPoint(LM_Vector2 pos, int32 frame);
	void DeletePoint(int32 id, bool preserveHandles = true);
	void DeleteSelectedPoints();
	bool WeldPoints(int32 movingID, int32 solidID, int32 frame);
	bool ArePointsAdjacent(int32 p1, int32 p2);
	void MakePointConsistentWithNeighbors(int32 id, int32 frame);
	void SimplifyCurve(int32 curveID, real angleTolerance);
	void AdvancedCurveSimplification(int32 curveID, int32 frame, real reductionEpsilon = 0.01f, real curveEpsilon = 0.01f, real splitThreshold = 0.1f);
	int32 IsCurveValid(M_Curve *curve);

	int32 ClosestPoint(LM_Vector2 &pos, int32 ignoreID = -1, int32 maxPointID = -1, bool endpointsOnly = false);
	LM_Vector2 SelectedCenter();
	void SelectedBounds(LM_Vector2 *min, LM_Vector2 *max);
	void PrepMovePoints();
	void PrepFixedHandles(int32 frame);
	void PreserveHandlePositions(int32 frame);
	void TranslatePoints(LM_Vector2 &offset);
	void ScalePoints(real sx, real sy, LM_Vector2 &centerVec, bool flipHandles = false);
	void RotatePoints(real angle, LM_Vector2 &centerVec);
	void TransformPoints(LM_Vector2 &offset, real sx, real sy, real angle, LM_Vector2 &centerVec);
	bool AllPointsUnbound();

	void SelectNone(); // deselects points and shapes
	void DeselectPoints(); // deselects just points
	void SelectAll();
	void SelectInverse();
	void SelectConnected();

	void DeleteEdge(int32 curveID, int32 segID, int32 frame, bool correctBezierHandles = true);

	void DeleteShape(int32 id);
	void LowerShape(int32 id, bool toBottom);
	void RaiseShape(int32 id, bool toTop);
	void PlaceShapeAbove(int32 shapeIDToMove, int32 shapeIDFixed);
	void PlaceShapeBehind(int32 shapeIDToMove, int32 shapeIDFixed);
	void StoreShapeOrder();
	int32 IsShapeValid(M_Shape *shape);
	int32 CombineShapes(M_Shape *shape1, M_Shape *shape2, int32 comboMode, real blendFactor, bool keepOriginals);
	int32 BakeCombinedShapes(M_Shape* shape, bool keepOriginals);

	void AddGroup(const char *name);
	void SelectGroup(const char *name);
	void DeleteGroup(const char *name);

	void EnableCleanup(bool on, bool guaranteedClean = false);

	int32 GetPointID @ PointID(M_Point *point);
	int32 GetCurveID @ CurveID(M_Curve *curve);
	int32 GetShapeID @ ShapeID(M_Shape *shape);
	int32 GetGroupID @ GroupID(M_PointGroup *group);
};

