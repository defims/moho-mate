class MohoLayerRenderOptions {
public:
	MohoLayerRenderOptions();
	~MohoLayerRenderOptions();
	static MohoLayerRenderOptions *new_local();

	// input options (default values listed in comments)
	int32		frame; // 0
	int32		minDimension; // 8 - minimum size of the rendered result (pixels)
	int32		maxDimension; // 1024 - maximum size of the rendered result (pixels)
	int32		polyDensity; // 10 - how many pixels per polygon (approximately). A value of 10 would mean that each square covers about 10 pixels in each direction.
	int32		polyCountX; // 20 - when building a mesh, how many polygons in the X direction (not used if polyDensity > 0)
	int32		polyCountY; // 20 - when building a mesh, how many polygons in the Y direction (not used if polyDensity > 0)
	bool		trimResult; // true
	LM_String	imageExtension; // "png" - can also be "jpg" or an empty string "" to produce no image output
	bool		embedColorProfile; // false - embed a color profile in the output image
	bool		debugResult; // false - display the output image in the GUI (useful for debugging scripts)

	// output results
	const char	*imagePath; // the path of the rendered image
	LM_BBox		layerBounds; // the bounds of the rendered image in document space
	M_Mesh3D	*mesh; // pass in a mesh object if you want to have Moho generate a mesh (can be NULL)
};

