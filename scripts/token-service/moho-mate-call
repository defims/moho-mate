#!/usr/bin/env node
/**
 * moho-mate 客户端 - 从 HTTP Token 服务获取 token
 */

const http = require('http');
const net = require('net');
const fs = require('fs');

// 配置
const TOKEN_SERVICE = process.env.MOHO_TOKEN_SERVICE || 'http://127.0.0.1:9527';
const IPC_SOCKET = '/tmp/moho_ipc.sock';
const CLIENT_ID = 'moho-mate';
const USER = process.env.USER || 'unknown';

// 日志
function log(level, message, data = {}) {
  const colors = { INFO: '\x1b[32m', WARN: '\x1b[33m', ERROR: '\x1b[31m', RESET: '\x1b[0m' };
  console.error(`${colors[level] || ''}[${level}]${colors.RESET} ${message}`, Object.keys(data).length ? data : '');
}

// HTTP POST 请求
function httpPost(path, body) {
  return new Promise((resolve, reject) => {
    const url = new URL(path, TOKEN_SERVICE);
    const data = JSON.stringify(body);
    
    const req = http.request({
      hostname: url.hostname,
      port: url.port,
      path: url.pathname,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': data.length
      }
    }, (res) => {
      let body = '';
      res.on('data', chunk => body += chunk);
      res.on('end', () => {
        try {
          resolve(JSON.parse(body));
        } catch (e) {
          reject(new Error(`Invalid JSON: ${body}`));
        }
      });
    });
    
    req.on('error', reject);
    req.write(data);
    req.end();
  });
}

// 从 Token 服务获取 token
async function getToken() {
  try {
    const result = await httpPost('/token/create', {
      client_id: CLIENT_ID,
      user: USER
    });
    
    if (result.error) {
      throw new Error(result.error);
    }
    
    log('INFO', `Token 已获取`, { expire: result.expire });
    return result.token;
    
  } catch (e) {
    log('ERROR', `获取 token 失败: ${e.message}`);
    throw e;
  }
}

// 发送命令到 IPC
function sendCommand(token, command) {
  return new Promise((resolve, reject) => {
    const socket = net.connect(IPC_SOCKET, () => {
      // 发送 auth + 命令（每个命令后等待响应）
      socket.write(`auth ${token}\n`);
    });
    
    let response = '';
    let authDone = false;
    
    socket.on('data', data => {
      response += data.toString();
      
      // 第一行是 auth 响应
      if (!authDone && response.includes('\n')) {
        authDone = true;
        // auth 成功后发送实际命令
        socket.write(`${command}\n`);
      }
      
      // 检查是否收到第二个响应
      const lines = response.trim().split('\n');
      if (authDone && lines.length >= 2) {
        socket.end();
      }
    });
    
    socket.on('end', () => {
      // 返回最后一个响应（命令结果）
      const lines = response.trim().split('\n');
      resolve(lines[lines.length - 1] || response.trim());
    });
    
    socket.on('error', reject);
    
    // 超时
    setTimeout(() => {
      socket.destroy();
      reject(new Error('timeout'));
    }, 10000);
  });
}

// 主函数
async function main() {
  const args = process.argv.slice(2);
  
  if (args.length === 0) {
    console.log(`
moho-mate-call - 通过 HTTP Token 服务认证的 IPC 客户端

用法:
  moho-mate-call '<lua>'
  moho-mate-call -f script.lua
  moho-mate-call --token-service <url>

环境变量:
  MOHO_TOKEN_SERVICE  Token 服务地址 (默认: http://127.0.0.1:9527)
`);
    process.exit(0);
  }
  
  // 解析参数
  let command = '';
  
  if (args[0] === '-f' && args[1]) {
    // 从文件读取
    command = fs.readFileSync(args[1], 'utf8');
  } else if (args[0] === '--token-service' && args[1]) {
    // 设置 token 服务地址
    process.env.MOHO_TOKEN_SERVICE = args[1];
    command = args.slice(2).join(' ');
  } else {
    command = args.join(' ');
  }
  
  if (!command) {
    log('ERROR', '缺少命令');
    process.exit(1);
  }
  
  try {
    // 获取 token
    const token = await getToken();
    
    // 发送命令
    const response = await sendCommand(token, command);
    
    // 解析响应
    if (response.startsWith('ok|')) {
      console.log(response.slice(3));
      process.exit(0);
    } else if (response.startsWith('error|')) {
      console.error(response);
      process.exit(1);
    } else {
      console.log(response);
      process.exit(0);
    }
    
  } catch (e) {
    log('ERROR', e.message);
    process.exit(1);
  }
}

main();
