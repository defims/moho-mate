[package]
name = "moho-mate"
version = "0.1.0"
edition = "2021"

# 单一可执行文件，同时充当 CLI 和 Lua 模块
# macOS 上可执行文件也可以被 dlopen 加载

[dependencies]
clap = { version = "4", features = ["derive"] }
anyhow = "1"
thiserror = "1"
tracing = "0.1"
tracing-subscriber = "0.3"

[build-dependencies]
cc = "1"

[profile.release]
opt-level = 3
lto = true
